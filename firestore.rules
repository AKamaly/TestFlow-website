rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /User Submissions/{document} {
      allow read, write: if true;  // This allows anyone to read and write to the User Submissions collection
    }
    
    match /{document=**} {
      allow read: if true;  // Allow reading all documents
      allow write: if false; // Restrict writing to other collections
    }
  }
} 